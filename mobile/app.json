{
  "expo": {
    "name": "MyDesignGhar",
    "slug": "mydesignghar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "mydesignghar",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mydesignghar.app",
      "icon": "./assets/logo.png",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MyDesignGhar needs access to your microphone to transcribe your speech design vision."
      }
    },
    "android": {
      "package": "com.mydesignghar.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc88929e-558d-496e-a406-456416479497"
      }
    },
    "owner": "adityagla"
  }
}
